# ZenAgent 环境变量配置
# 复制此文件为 .env 并填写实际值

# ===================
# LLM API Keys
# ===================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ERNIE_API_KEY=your-ernie-api-key
ERNIE_SECRET_KEY=your-ernie-secret-key
DASHSCOPE_API_KEY=your-dashscope-api-key
ZHIPU_API_KEY=your-zhipu-api-key

# ===================
# Model Nexus Configuration
# ===================
MODELNEXUS_URL=http://localhost:8080
MODELNEXUS_API_KEY=your-modelnexus-key-here

# ===================
# Redis (for LLM caching)
# ===================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_CACHE_ENABLED=true
REDIS_CACHE_TTL=3600

# ===================
# ZenAgent Configuration
# ===================
DEFAULT_LLM_PROVIDER=mock
DEFAULT_LLM_MODEL=gpt-3.5-turbo
ENABLE_MEMORY_SYSTEM=true
ENABLE_PERSONALITY_SYSTEM=true
AUTO_MEMORY_RECORDING=true

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
DEBUG=false
ENVIRONMENT=development

# ===================
# Nacos (Optional)
# ===================
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ===================
# APISIX Admin (Optional)
# ===================
APISIX_ADMIN_KEY=your-secret-key-change-in-production

# ===================
# Prefect (Optional)
# ===================
PREFECT_API_KEY=your-prefect-api-key

# LLMInfra 配置示例

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-3.5-turbo

# 通义千问配置 (可选)
# QIANWEN_API_KEY=your-qianwen-api-key
# QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QIANWEN_DEFAULT_MODEL=qwen-turbo

# 智谱AI配置 (可选)
# ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_DEFAULT_MODEL=glm-4

# 文心一言配置 (可选)
# ERNIE_API_KEY=your-ernie-api-key
# ERNIE_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
# ERNIE_DEFAULT_MODEL=ernie-4.0

# Claude配置 (可选)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_DEFAULT_MODEL=claude-2

# 缓存配置
LLM_CACHE_ENABLED=true
LLM_CACHE_TYPE=redis
LLM_CACHE_REDIS_URL=redis://localhost:6379/0
LLM_CACHE_TTL=3600

# 限流配置
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS_PER_MINUTE=60
LLM_RATE_LIMIT_TOKENS_PER_MINUTE=90000

# 默认提供商
LLM_DEFAULT_PROVIDER=openai

# 日志配置
LLM_LOG_LEVEL=INFO
